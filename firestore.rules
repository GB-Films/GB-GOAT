rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function userEmail() {
      return request.auth.token.email;
    }

    function isAppOwner() {
      return isSignedIn() && userEmail() == 'info@granbertafilms.com';
    }

    function isAppAdmin() {
      return isSignedIn()
        && (
          isAppOwner()
          || (
            exists(/databases/$(database)/documents/users/$(request.auth.uid))
            && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'
          )
        );
    }

    function projectDoc(projectId) {
      return get(/databases/$(database)/documents/projects/$(projectId)).data;
    }

    function collaboratorDoc(projectId) {
      return get(/databases/$(database)/documents/projects/$(projectId)/collaborators/$(userEmail())).data;
    }

    function hasCollaboratorDoc(projectId) {
      return isSignedIn()
        && exists(/databases/$(database)/documents/projects/$(projectId)/collaborators/$(userEmail()));
    }

    function isProjectOwner(projectId) {
      return isSignedIn() && projectDoc(projectId).createdBy == request.auth.uid;
    }

    function isProjectCollaborator(projectId) {
      return isSignedIn()
        && (
          hasCollaboratorDoc(projectId)
          || userEmail() in projectDoc(projectId).collaboratorEmails
        );
    }

    function isProjectAdmin(projectId) {
      return isAppAdmin()
        || isProjectOwner(projectId)
        || (
          hasCollaboratorDoc(projectId)
          && collaboratorDoc(projectId).role == 'admin'
        );
    }

    function hasProjectAccess(projectId) {
      return isProjectAdmin(projectId) || isProjectCollaborator(projectId);
    }

    function canWriteArea(projectId, area) {
      return isProjectAdmin(projectId)
        || (
          hasCollaboratorDoc(projectId)
          && collaboratorDoc(projectId).canEditBudgetAreas == true
          && area in collaboratorDoc(projectId).allowedCategories
          && 'areas' in collaboratorDoc(projectId).allowedTabs
        );
    }

    function inviteIsPending(token) {
      return token is string
        && exists(/databases/$(database)/documents/providerInvites/$(token))
        && get(/databases/$(database)/documents/providerInvites/$(token)).data.used == false
        && get(/databases/$(database)/documents/providerInvites/$(token)).data.status == 'pending';
    }

    function publicProviderCreateIsValid() {
      return request.auth == null
        && request.resource.data.source == 'provider_invite'
        && inviteIsPending(request.resource.data.inviteToken)
        && request.resource.data.type in ['persona', 'empresa']
        && request.resource.data.cuitNormalized is string
        && request.resource.data.category is string
        && request.resource.data.email is string
        && request.resource.data.phone is string
        && request.resource.data.address is string;
    }

    match /users/{userId} {
      allow get, list: if isSignedIn();
      allow create: if isSignedIn() && (
        isAppOwner()
        || (
          request.auth.uid == userId
          && request.resource.data.role == 'colaborador'
        )
      );
      allow update: if isAppOwner()
        || (
          isSignedIn()
          && request.auth.uid == userId
          && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role'])
        );
      allow delete: if isAppOwner();
    }

    // The user directory is readable by signed-in users so project admins can add
    // already-logged collaborators without giving them global admin privileges.

    match /projects/{projectId} {
      allow list: if isAppAdmin() || (
        isSignedIn()
        && (
          resource.data.createdBy == request.auth.uid
          || userEmail() in resource.data.collaboratorEmails
        )
      );
      allow get: if hasProjectAccess(projectId);
      allow create: if isAppAdmin() && request.resource.data.createdBy == request.auth.uid;
      allow update: if isProjectAdmin(projectId);
      allow delete: if isAppAdmin();

      match /collaborators/{email} {
        allow read: if hasProjectAccess(projectId);
        allow create, update, delete: if isProjectAdmin(projectId);
      }

      match /budgetItems/{itemId} {
        allow read: if hasProjectAccess(projectId);
        allow create, update, delete: if isProjectAdmin(projectId);
      }

      match /areaExpenses/{expenseId} {
        allow read: if hasProjectAccess(projectId);
        allow create: if canWriteArea(projectId, request.resource.data.area);
        allow update: if canWriteArea(projectId, resource.data.area)
          && canWriteArea(projectId, request.resource.data.area);
        allow delete: if canWriteArea(projectId, resource.data.area);
      }

      match /expenses/{expenseId} {
        allow read, write: if hasProjectAccess(projectId);
      }

      match /milestones/{milestoneId} {
        allow read, write: if hasProjectAccess(projectId);
      }

      match /teamMembers/{memberId} {
        allow read, write: if hasProjectAccess(projectId);
      }

      match /payments/{paymentId} {
        allow read, write: if hasProjectAccess(projectId);
      }

      match /invoices/{invoiceId} {
        allow read, write: if hasProjectAccess(projectId);
      }

      match /projectDocuments/{documentId} {
        allow read: if hasProjectAccess(projectId);
        allow create, update, delete: if isProjectAdmin(projectId);
      }
    }

    match /clients/{clientId} {
      allow read: if isSignedIn();
      allow write: if isAppAdmin();
    }

    match /providers/{providerId} {
      allow read: if isSignedIn();
      allow create: if isAppAdmin() || publicProviderCreateIsValid();
      allow update, delete: if isAppAdmin();
    }

    match /providerInvites/{token} {
      allow get: if true;
      allow list: if isAppAdmin();
      allow create: if isAppAdmin()
        && request.resource.data.status == 'pending'
        && request.resource.data.used == false;
      allow update: if isAppAdmin()
        || (
          request.auth == null
          && resource.data.used == false
          && resource.data.status == 'pending'
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['used', 'status', 'usedAt', 'providerId', 'providerType'])
          && request.resource.data.used == true
          && request.resource.data.status == 'used'
          && request.resource.data.providerId is string
          && request.resource.data.providerType in ['persona', 'empresa']
        );
      allow delete: if isAppAdmin();
    }

    match /providerIdentifiers/{identifierId} {
      allow get: if true;
      allow list: if isAppAdmin();
      allow create: if isAppAdmin()
        || (
          request.auth == null
          && request.resource.data.inviteToken is string
          && inviteIsPending(request.resource.data.inviteToken)
          && request.resource.data.providerId is string
          && request.resource.data.identifierType in ['dni', 'cuit']
          && request.resource.data.value is string
        );
      allow update, delete: if isAppAdmin();
    }
  }
}
