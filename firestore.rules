rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function userEmail() {
      return request.auth.token.email;
    }

    function isAppOwner() {
      return isSignedIn() && userEmail() == 'info@granbertafilms.com';
    }

    function projectDoc(projectId) {
      return get(/databases/$(database)/documents/projects/$(projectId)).data;
    }

    function isProjectOwner(projectId) {
      return isSignedIn() && projectDoc(projectId).createdBy == request.auth.uid;
    }

    function isProjectCollaborator(projectId) {
      return isSignedIn() && userEmail() in projectDoc(projectId).collaboratorEmails;
    }

    function hasProjectAccess(projectId) {
      return isAppOwner() || isProjectOwner(projectId) || isProjectCollaborator(projectId);
    }

    match /users/{userId} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn() && (request.auth.uid == userId || isAppOwner());
      allow delete: if isAppOwner();
    }

    match /projects/{projectId} {
      allow list: if isSignedIn();
      allow get: if hasProjectAccess(projectId);
      allow create: if isSignedIn() && request.resource.data.createdBy == request.auth.uid;
      allow update, delete: if isAppOwner() || isProjectOwner(projectId);

      match /collaborators/{email} {
        allow read: if hasProjectAccess(projectId);
        allow write: if isAppOwner() || isProjectOwner(projectId);
      }

      match /{subcollection}/{documentId} {
        allow read, write: if hasProjectAccess(projectId);
      }
    }

    match /clients/{clientId} {
      allow read, write: if isSignedIn();
    }

    match /providers/{providerId} {
      allow read, write: if isSignedIn();
    }
  }
}
